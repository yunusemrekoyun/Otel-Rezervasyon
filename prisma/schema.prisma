generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  users     User[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String                   @map("password_hash")
  isActive                Boolean                  @default(true) @map("is_active")
  roleId                  String                   @map("role_id")
  role                    Role                     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  sessions                Session[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  accountPeople           AccountPerson[]
  reservations            Reservation[]
  contactRequests         ContactRequest[]
  experienceBookings      ExperienceBooking[]
  assignedTasks           CleaningTask[]           @relation("assigned_tasks")
  reportedTasks           CleaningTask[]           @relation("reported_tasks")
  maintenanceReports      MaintenanceReport[]
  lostItems               LostItem[]
  // Profile
  firstName               String?                  @map("first_name")
  lastName                String?                  @map("last_name")
  phone                   String?
  birthDate               DateTime?                @map("birth_date")
  gender                  String?
  nationality             String?                  @default("TR")
  tcKimlikNo              String?                  @map("tc_kimlik_no")
  passportNo              String?                  @map("passport_no")
  passportExpiry          DateTime?                @map("passport_expiry")
  companyName             String?                  @map("company_name")
  taxNumber               String?                  @map("tax_number")
  taxOffice               String?                  @map("tax_office")
  emailVerified           Boolean                  @default(false) @map("email_verified")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")

  @@index([roleId])
  @@map("users")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model Session {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  userAgent  String?   @map("user_agent")
  ipAddress  String?   @map("ip_address")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  lastUsedAt DateTime  @default(now()) @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model AccountPerson {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  label          String?
  relation       String    @default("self")
  isDefault      Boolean   @default(false) @map("is_default")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  email          String?
  phone          String?
  birthDate      DateTime? @map("birth_date")
  gender         String?
  nationality    String?   @default("TR")
  tcKimlikNo     String?   @map("tc_kimlik_no")
  passportNo     String?   @map("passport_no")
  passportExpiry DateTime? @map("passport_expiry")
  companyName    String?   @map("company_name")
  taxNumber      String?   @map("tax_number")
  taxOffice      String?   @map("tax_office")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([userId, isDefault])
  @@map("account_people")
}

model Reservation {
  id                          String    @id @default(cuid())
  confirmationId              String    @unique @map("confirmation_id")
  // Room
  roomId                      String    @map("room_id")
  room                        Room      @relation(fields: [roomId], references: [id], onDelete: Restrict)
  // Dates
  checkInDate                 DateTime  @map("check_in_date")
  checkOutDate                DateTime  @map("check_out_date")
  nights                      Int
  // Guest counts
  adultsCount                 Int       @default(1) @map("adults_count")
  childrenCount               Int       @default(0) @map("children_count")
  // Guest identity
  firstName                   String    @map("first_name")
  lastName                    String    @map("last_name")
  email                       String
  phone                       String
  birthDate                   DateTime? @map("birth_date")
  gender                      String?
  nationality                 String?   @default("TR")
  // Legal ID
  tcKimlikNo                  String?   @map("tc_kimlik_no")
  passportNo                  String?   @map("passport_no")
  passportExpiry              DateTime? @map("passport_expiry")
  // Corporate (optional)
  companyName                 String?   @map("company_name")
  taxNumber                   String?   @map("tax_number")
  taxOffice                   String?   @map("tax_office")
  // Pricing
  subtotal                    Int
  totalPrice                  Int       @map("total_price")
  // Extra
  specialRequests             String?   @map("special_requests")
  vehiclePlate                String?   @map("vehicle_plate")
  checkinNote                 String?   @map("checkin_note")
  checkinDocumentUrl          String?   @map("checkin_document_url")
  checkinDocumentPrivatePath  String?   @map("checkin_document_private_path")
  checkinDocumentOriginalName String?   @map("checkin_document_original_name")
  checkinDocumentMimeType     String?   @map("checkin_document_mime_type")
  checkinDocumentSize         Int?      @map("checkin_document_size")
  checkinDocumentUploadedAt   DateTime? @map("checkin_document_uploaded_at")
  status                      String    @default("pending")
  // Optional user account link
  userId                      String?   @map("user_id")
  user                        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")

  @@index([roomId])
  @@index([userId])
  @@index([checkInDate, checkOutDate])
  @@map("reservations")
}

model ContactRequest {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  name      String
  category  String
  message   String
  ticketId  String   @unique @map("ticket_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("contact_requests")
}

model ExperienceBooking {
  id                  String   @id @default(cuid())
  userId              String?  @map("user_id")
  experienceId        String   @map("experience_id")
  experienceName      String   @map("experience_name")
  date                DateTime
  guests              Int
  basePrice           Int      @map("base_price")
  insuranceAndGearFee Int      @map("insurance_and_gear_fee")
  totalPrice          Int      @map("total_price")
  confirmationId      String   @unique @map("confirmation_id")
  createdAt           DateTime @default(now()) @map("created_at")
  user                User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([experienceId])
  @@map("experience_bookings")
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model RoomType {
  id        String   @id @default(cuid())
  name      String
  amenities String[]
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  rooms     Room[]

  @@map("room_types")
}

model Room {
  id                 String              @id @default(cuid())
  name               String
  floor              Int?
  status             String              @default("available")
  basePrice          Int                 @map("base_price")
  description        String?
  isActive           Boolean             @default(true) @map("is_active")
  sortOrder          Int                 @default(0) @map("sort_order")
  maxAdults          Int                 @default(2) @map("max_adults")
  maxChildren        Int                 @default(0) @map("max_children")
  roomTypeId         String              @map("room_type_id")
  roomType           RoomType            @relation(fields: [roomTypeId], references: [id], onDelete: Restrict)
  reservations       Reservation[]
  cleaningTasks      CleaningTask[]
  maintenanceReports MaintenanceReport[]
  lostItems          LostItem[]
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@index([roomTypeId])
  @@map("rooms")
}

model CleaningTask {
  id           String    @id @default(cuid())
  roomId       String    @map("room_id")
  room         Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  assignedToId String?   @map("assigned_to_id")
  assignedTo   User?     @relation("assigned_tasks", fields: [assignedToId], references: [id], onDelete: SetNull)
  reportedById String    @map("reported_by_id")
  reportedBy   User      @relation("reported_tasks", fields: [reportedById], references: [id], onDelete: Restrict)
  status       String    @default("pending") // pending | in_progress | done
  priority     String    @default("normal") // normal | urgent
  notes        String?
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([roomId])
  @@index([assignedToId])
  @@map("cleaning_tasks")
}

model MaintenanceReport {
  id           String   @id @default(cuid())
  roomId       String   @map("room_id")
  room         Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  reportedById String   @map("reported_by_id")
  reportedBy   User     @relation(fields: [reportedById], references: [id], onDelete: Restrict)
  description  String
  priority     String   @default("normal") // normal | urgent
  status       String   @default("open") // open | resolved
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([roomId])
  @@map("maintenance_reports")
}

model LostItem {
  id          String   @id @default(cuid())
  roomId      String   @map("room_id")
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  foundById   String   @map("found_by_id")
  foundBy     User     @relation(fields: [foundById], references: [id], onDelete: Restrict)
  description String
  status      String   @default("found") // found | claimed | discarded
  foundAt     DateTime @default(now()) @map("found_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([roomId])
  @@map("lost_items")
}

model Media {
  id           String   @id @default(cuid())
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  size         Int
  pathOriginal String   @map("path_original")
  pathThumb    String?  @map("path_thumb")
  pathMedium   String?  @map("path_medium")
  pathLarge    String?  @map("path_large")
  isProcessed  Boolean  @default(false) @map("is_processed")
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@map("media")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?  @map("actor_user_id")
  actorEmail  String?  @map("actor_email")
  actorRole   String?  @map("actor_role")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  summary     String
  before      Json?
  after       Json?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([actorUserId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
